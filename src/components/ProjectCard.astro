---
import type { Project } from '@/data/projects';
interface Props {
  project: Project;
  number: number;
}
const { project, number } = Astro.props;
const disciplineLabel: Record<Project['discipline'], string> = {
  DE: 'Data Eng',
  DS: 'Data Science',
  AI: 'AI Eng',
};
---

<a
  href={project.href}
  target="_blank"
  rel="noreferrer"
  class="group card p-4 md:p-5 flex flex-col fade-up"
>
  <div class="flex items-center justify-between">
    <span class="font-mono text-[10.5px] tracking-widest text-subtle">
      {String(number).padStart(2, '0')}
    </span>
    <span class="font-mono text-[10.5px] tracking-widest uppercase text-accent">
      {disciplineLabel[project.discipline]}
    </span>
  </div>

  <div
    class="mt-4 relative aspect-[16/10] overflow-hidden rounded-md bg-ink/5 border border-border"
  >
    <img
      src={project.image}
      alt={project.title}
      loading="lazy"
      decoding="async"
      class="absolute inset-0 h-full w-full object-cover transition duration-500 ease-out group-hover:scale-[1.02]"
    />
  </div>

  <h3
    class="mt-4 text-[15px] md:text-[16px] font-semibold tracking-tight leading-snug text-ink group-hover:text-accent transition-colors"
  >
    {project.title}
  </h3>

  <ul class="mt-3 flex flex-wrap gap-1.5">
    {
      project.stack.map((s) => (
        <li class="chip">
          {s}
        </li>
      ))
    }
  </ul>

  <div
    class="mt-4 pt-3 border-t border-border flex items-center justify-between text-[11px] font-mono uppercase tracking-widest text-subtle"
  >
    <span class="group-hover:text-ink transition">{project.level}</span>
    <span class="inline-flex items-center gap-1 group-hover:text-ink transition">
      View
      <svg
        class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"><path d="M7 17L17 7M9 7h8v8"></path></svg
      >
    </span>
  </div>
</a>
