---
interface Props {
  index: string;
  label: string;
  title: string;
  kicker?: string;
}
const { index, label, title, kicker } = Astro.props;
---

<header class="max-w-page mx-auto px-5 md:px-8 pt-14 md:pt-20 pb-6">
  <div class="flex items-baseline justify-between gap-4 fade-up">
    <p class="font-mono text-[11px] tracking-[0.16em] uppercase text-subtle">
      <span class="text-accent">§ {index}</span>
      <span class="opacity-50">·</span>
      <span>{label}</span>
    </p>
    {kicker && <p class="hidden md:block mono-label opacity-60">{kicker}</p>}
  </div>
  <h2
    class="mt-3 text-[22px] md:text-[28px] font-semibold tracking-tight text-ink leading-tight fade-up"
  >
    {title}
  </h2>
</header>
