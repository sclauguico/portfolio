---
---

<div
  class="fixed bottom-4 left-4 right-4 sm:bottom-5 sm:left-auto sm:right-5 sm:max-w-sm z-50 hidden print:hidden"
  data-consent-toast
  role="region"
  aria-label="Analytics consent"
>
  <div class="rounded-lg border border-border bg-surface shadow-xl p-4">
    <p class="text-[13.5px] leading-relaxed text-ink">
      This site uses privacy-friendly analytics to understand what visitors find useful.
      No tracking cookies are set unless you opt in.
    </p>
    <p class="mt-2 text-[12px] text-muted">
      <a
        href="/privacy#analytics"
        class="font-medium text-ink underline decoration-ink/40 underline-offset-2 hover:decoration-ink transition"
      >What gets collected</a>
    </p>
    <div class="mt-3 flex items-center gap-2">
      <button
        type="button"
        class="btn-primary flex-1"
        data-consent-allow
      >Allow</button>
      <button
        type="button"
        class="flex-1 h-9 px-3 rounded-md border border-border text-[13px] text-ink hover:bg-ink/5 transition"
        data-consent-decline
      >Decline</button>
    </div>
  </div>
</div>

<script>
  import { getConsent, setConsent } from '@/scripts/consent';

  const toast = document.querySelector<HTMLElement>('[data-consent-toast]');
  if (toast) {
    const show = () => toast.classList.remove('hidden');
    const hide = () => toast.classList.add('hidden');

    if (getConsent() === null) {
      show();
    }

    toast.querySelector<HTMLButtonElement>('[data-consent-allow]')
      ?.addEventListener('click', () => {
        setConsent({ analytics: true });
        hide();
      });

    toast.querySelector<HTMLButtonElement>('[data-consent-decline]')
      ?.addEventListener('click', () => {
        setConsent({ analytics: false });
        hide();
      });
  }
</script>
