---
interface Props {
  email: string;
  variant?: 'primary' | 'link';
  className?: string;
  label?: string;
  icon?: boolean;
  surface?: string;
}

const {
  email,
  variant = 'primary',
  className = '',
  label,
  icon = true,
  surface = 'unknown',
} = Astro.props;

const displayLabel = label ?? email;

const gmail = `https://mail.google.com/mail/?view=cm&fs=1&to=${encodeURIComponent(email)}`;
const outlook = `https://outlook.office.com/mail/deeplink/compose?to=${encodeURIComponent(email)}`;
const mailto = `mailto:${email}`;

const triggerClass =
  variant === 'primary'
    ? `btn-primary ${className}`
    : `text-[13.5px] text-ink link-underline ${className}`;
---

<details class="email-menu relative inline-block" data-email={email} data-surface={surface}>
  <summary
    class={`${triggerClass} list-none cursor-pointer select-none`}
    role="button"
    aria-haspopup="menu"
  >
    {icon && variant === 'primary' && (
      <svg
        class="h-4 w-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
        <path d="M3 7l9 6 9-6"></path>
      </svg>
    )}
    <span>{displayLabel}</span>
    {variant === 'primary' && (
      <svg
        class="h-3 w-3 opacity-70 transition group-open:rotate-180"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M6 9l6 6 6-6"></path>
      </svg>
    )}
  </summary>

  <div
    class="email-menu-panel absolute left-0 top-full mt-2 min-w-[240px] rounded-lg border border-border bg-surface p-1.5 z-20 shadow-lg"
    role="menu"
  >
    <a
      href={gmail}
      target="_blank"
      rel="noreferrer"
      role="menuitem"
      class="email-menu-item"
    >
      <span class="email-menu-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" class="h-4 w-4">
          <path fill="#EA4335" d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/>
        </svg>
      </span>
      <div class="flex-1">
        <p class="text-[13px] text-ink font-medium">Open in Gmail</p>
        <p class="text-[11px] text-subtle">New tab, pre-addressed</p>
      </div>
      <svg class="h-3.5 w-3.5 text-subtle" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8"></path></svg>
    </a>

    <a
      href={outlook}
      target="_blank"
      rel="noreferrer"
      role="menuitem"
      class="email-menu-item"
    >
      <span class="email-menu-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" class="h-4 w-4">
          <path fill="#0078D4" d="M7.88 12.04q0 .45-.11.87-.1.41-.33.74-.22.33-.58.52-.37.2-.87.2t-.85-.2q-.37-.2-.62-.53-.25-.33-.37-.74-.12-.42-.12-.86t.12-.86.37-.75.62-.52.85-.2q.5 0 .87.2.36.2.58.52.23.33.33.75t.11.87M24 3v18a1 1 0 0 1-1 1H11a1 1 0 0 1-1-1v-3H1a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h9V3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1M9 13.11a4.11 4.11 0 0 0-.46-1.94 3.23 3.23 0 0 0-1.3-1.35 4 4 0 0 0-2-.48 4.1 4.1 0 0 0-2.1.51 3.5 3.5 0 0 0-1.37 1.4 4.4 4.4 0 0 0-.48 2.06 4.2 4.2 0 0 0 .47 2 3.33 3.33 0 0 0 1.32 1.37 4 4 0 0 0 2 .48 4.3 4.3 0 0 0 2.13-.51 3.38 3.38 0 0 0 1.36-1.39 4.38 4.38 0 0 0 .48-2.1zM23 20V6h-9v4h2a2 2 0 0 1 2 2v6h-1.5v-5.5a1.5 1.5 0 0 0-3 0V20z"/>
        </svg>
      </span>
      <div class="flex-1">
        <p class="text-[13px] text-ink font-medium">Open in Outlook</p>
        <p class="text-[11px] text-subtle">New tab, pre-addressed</p>
      </div>
      <svg class="h-3.5 w-3.5 text-subtle" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8"></path></svg>
    </a>

    <a
      href={mailto}
      role="menuitem"
      class="email-menu-item"
    >
      <span class="email-menu-icon" aria-hidden="true">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="M3 7l9 6 9-6"></path>
        </svg>
      </span>
      <div class="flex-1">
        <p class="text-[13px] text-ink font-medium">Default mail app</p>
        <p class="text-[11px] text-subtle">Apple Mail, Thunderbird, etc.</p>
      </div>
    </a>

    <button
      type="button"
      class="email-menu-item w-full text-left"
      data-copy
      role="menuitem"
    >
      <span class="email-menu-icon" aria-hidden="true">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2"></rect>
          <path d="M5 15V5a2 2 0 0 1 2-2h10"></path>
        </svg>
      </span>
      <div class="flex-1">
        <p class="text-[13px] text-ink font-medium" data-copy-label>
          Copy address
        </p>
        <p class="text-[11px] text-subtle">{email}</p>
      </div>
    </button>
  </div>
</details>

<style>
  .email-menu summary::-webkit-details-marker {
    display: none;
  }
  .email-menu summary::marker {
    display: none;
  }
  .email-menu-panel {
    box-shadow:
      0 4px 16px rgb(10 10 10 / 0.08),
      0 1px 2px rgb(10 10 10 / 0.06);
  }
  :root.dark .email-menu-panel {
    box-shadow: 0 0 0 1px rgb(var(--ink) / 0.06), 0 8px 24px rgb(0 0 0 / 0.4);
  }
  .email-menu-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.625rem;
    border-radius: 6px;
    transition: background 150ms ease;
  }
  .email-menu-item:hover,
  .email-menu-item:focus-visible {
    background: rgb(var(--ink) / 0.04);
    outline: none;
  }
  .email-menu-icon {
    display: inline-grid;
    place-items: center;
    height: 28px;
    width: 28px;
    border-radius: 6px;
    background: rgb(var(--ink) / 0.04);
    color: rgb(var(--muted));
    flex-shrink: 0;
  }
  .email-menu[open] summary svg:last-child {
    transform: rotate(180deg);
  }
</style>

<script>
  import { track } from '@/scripts/track';

  document.querySelectorAll<HTMLDetailsElement>('.email-menu').forEach((el) => {
    const email = el.dataset.email ?? '';
    const surface = el.dataset.surface ?? 'unknown';

    el.querySelector<HTMLElement>('summary')?.addEventListener('click', () => {
      if (!el.open) track('contact_email_click', { surface });
    });

    document.addEventListener('click', (e) => {
      if (el.open && !el.contains(e.target as Node)) {
        el.removeAttribute('open');
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && el.open) el.removeAttribute('open');
    });

    const copyBtn = el.querySelector<HTMLButtonElement>('[data-copy]');
    const copyLabel = el.querySelector<HTMLElement>('[data-copy-label]');
    copyBtn?.addEventListener('click', async (e) => {
      e.preventDefault();
      try {
        await navigator.clipboard.writeText(email);
        if (copyLabel) {
          const original = copyLabel.textContent;
          copyLabel.textContent = 'Copied!';
          setTimeout(() => {
            if (copyLabel) copyLabel.textContent = original ?? 'Copy address';
          }, 1200);
        }
      } catch {}
      setTimeout(() => el.removeAttribute('open'), 400);
    });
  });
</script>
